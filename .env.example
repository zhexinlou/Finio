# ===========================================
# Finio Environment Configuration
# Copy this file to .env and fill in values
# ===========================================

# ---- AI Service (DashScope / Qwen) ----
DASHSCOPE_API_KEY=your_dashscope_api_key
WAREHOUSE_PATH=/absolute/path/to/Finio/warehouse
PYTHON_SERVICE_URL=http://localhost:8000

# ---- Database (production) ----
DB_PASSWORD=your_database_password
MYSQL_ROOT_PASSWORD=your_root_password

# ---- JWT Secret (must be at least 256 bits / 32 chars) ----
JWT_SECRET=change-this-to-a-very-long-random-secret-at-least-256-bits-long

# ---- WeChat OAuth (open.weixin.qq.com) ----
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ---- Email Service ----
EMAIL_ENABLED=false
EMAIL_FROM=noreply@finio.ai

# ---- App URL ----
APP_BASE_URL=https://your-domain.com

# ---- Redis ----
REDIS_PASSWORD=your_redis_password
